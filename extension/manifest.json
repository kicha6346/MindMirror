{
  "manifest_version": 3,
  "name": "MindMirror",
  "version": "1.0",
  "description": "Tracks your digital behavior and browser usage to detect burnout patterns.",
  "permissions": ["tabs", "storage", "alarms", "idle"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MindMirror",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
